<model>
    <mount>//OPNsense/netshield</mount>
    <version>1.0.0</version>
    <description>NetShield — Advanced network security and monitoring</description>
    <items>
        <general>
            <enabled type="BooleanField">
                <Default>1</Default>
            </enabled>
            <telegram_bot_token type="TextField">
                <Required>Y</Required>
            </telegram_bot_token>
            <telegram_chat_id type="TextField">
                <Required>Y</Required>
            </telegram_chat_id>
            <dpi_enabled type="BooleanField">
                <Default>1</Default>
            </dpi_enabled>
            <dns_filtering_enabled type="BooleanField">
                <Default>1</Default>
            </dns_filtering_enabled>
            <device_tracking_enabled type="BooleanField">
                <Default>1</Default>
            </device_tracking_enabled>
            <threat_intel_enabled type="BooleanField">
                <Default>1</Default>
            </threat_intel_enabled>
            <alert_cooldown type="IntegerField">
                <Default>15</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>1440</MaximumValue>
            </alert_cooldown>
            <check_interval type="IntegerField">
                <Default>30</Default>
                <MinimumValue>10</MinimumValue>
                <MaximumValue>300</MaximumValue>
            </check_interval>
            <excluded_devices type="CSVListField"/>
            <new_device_alert type="BooleanField">
                <Default>1</Default>
            </new_device_alert>
            <auto_quarantine_unknown type="BooleanField">
                <Default>0</Default>
            </auto_quarantine_unknown>
            <log_level type="OptionField">
                <Default>INFO</Default>
                <OptionValues>
                    <INFO>INFO</INFO>
                    <DEBUG>DEBUG</DEBUG>
                    <WARNING>WARNING</WARNING>
                    <ERROR>ERROR</ERROR>
                </OptionValues>
            </log_level>
            <syslog_enabled type="BooleanField">
                <Default>0</Default>
                <Required>N</Required>
            </syslog_enabled>
            <syslog_host type="TextField">
                <Default></Default>
                <Required>N</Required>
            </syslog_host>
            <syslog_port type="IntegerField">
                <Default>514</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>65535</MaximumValue>
                <Required>N</Required>
            </syslog_port>
            <syslog_protocol type="OptionField">
                <Default>udp</Default>
                <OptionValues>
                    <udp>UDP</udp>
                    <tcp>TCP</tcp>
                </OptionValues>
                <Required>N</Required>
            </syslog_protocol>
        </general>
    </items>
</model>
